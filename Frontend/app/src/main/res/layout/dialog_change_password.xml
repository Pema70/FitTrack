<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">
    <EditText android:id="@+id/etOldPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Stare haslo"
        android:inputType="textPassword"
        android:layout_marginBottom="12dp"/>
    <EditText android:id="@+id/etNewPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nowe haslo (min. 8 znakow, 1 cyfra)"
        android:inputType="textPassword"
        android:layout_marginBottom="12dp"/>
    <EditText android:id="@+id/etNewPasswordConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Powtorz nowe haslo"
        android:inputType="textPassword"/>
</LinearLayout>
